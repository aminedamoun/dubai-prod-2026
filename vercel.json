{
  "buildCommand": "",
  "outputDirectory": ".",
  "redirects": [
    { "source": "/pr.html", "destination": "/pr-media", "statusCode": 301 },
    { "source": "/pr", "destination": "/pr-media", "statusCode": 301 },
    { "source": "/about.html", "destination": "/about-us-dubai", "statusCode": 301 },
    { "source": "/about", "destination": "/about-us-dubai", "statusCode": 301 },
    { "source": "/contact.html", "destination": "/contact-dubai", "statusCode": 301 },
    { "source": "/contact", "destination": "/contact-dubai", "statusCode": 301 },
    { "source": "/cgi-3d-dubai.html", "destination": "/cgi-3d", "statusCode": 301 },
    { "source": "/cgi-3d-dubai", "destination": "/cgi-3d", "statusCode": 301 },
    { "source": "/3d-cgi-dubai.html", "destination": "/cgi-3d", "statusCode": 301 },
    { "source": "/3d-cgi-dubai", "destination": "/cgi-3d", "statusCode": 301 },
    { "source": "/video-production-agency-dubai.html", "destination": "/video-production-dubai", "statusCode": 301 },
    { "source": "/video-production-agency-dubai", "destination": "/video-production-dubai", "statusCode": 301 },
    { "source": "/ads-management-agency-dubai.html", "destination": "/ads", "statusCode": 301 },
    { "source": "/ads-management-agency-dubai", "destination": "/ads", "statusCode": 301 },
    { "source": "/seo-agency-dubai-uae.html", "destination": "/seo", "statusCode": 301 },
    { "source": "/seo-agency-dubai-uae", "destination": "/seo", "statusCode": 301 },
    { "source": "/social-media-agency-dubai.html", "destination": "/social-media", "statusCode": 301 },
    { "source": "/social-media-agency-dubai", "destination": "/social-media", "statusCode": 301 },
    { "source": "/social-media-dubai.html", "destination": "/social-media", "statusCode": 301 },
    { "source": "/social-media-dubai", "destination": "/social-media", "statusCode": 301 },
    { "source": "/web-development-dubai-agency.html", "destination": "/web-development", "statusCode": 301 },
    { "source": "/web-development-dubai-agency", "destination": "/web-development", "statusCode": 301 },
    { "source": "/portfolio.html", "destination": "/portfolio-dubai", "statusCode": 301 },
    { "source": "/portfolio", "destination": "/portfolio-dubai", "statusCode": 301 },
    { "source": "/blog.html", "destination": "/blog-dubai", "statusCode": 301 },
    { "source": "/blog", "destination": "/blog-dubai", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).webp",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" },
        { "key": "Content-Type", "value": "image/webp" }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
